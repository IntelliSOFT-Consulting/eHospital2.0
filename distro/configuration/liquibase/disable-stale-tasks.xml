<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-2.0.xsd">

    <changeSet id="disable-stale-appointment-tasks-1" author="ehospital">
        <update tableName="scheduler_task_config">
            <column name="start_on_startup" valueNumeric="0"/>
            <where>schedulable_class LIKE '%appointments.scheduler.tasks%'</where>
        </update>
    </changeSet>

    <changeSet id="inject-xstream-whitelist-global-property-1" author="ehospital">
        <!-- 
            Why is this here instead of just globalproperties-core_data.xml?
            The OpenMRS Initializer module processes globalproperties-core_data.xml during module startup.
            However, the 'ehospitalreports' module tries to deserialize report definitions BEFORE the
            Initializer has finished loading global properties. If the XStream whitelist is not already in 
            the database, the server will crash with a ForbiddenClassException. 
            
            By injecting this via Liquibase, we guarantee the property is in the database before ANY 
            modules start loading, completely preventing the exception even on a fresh database restore!
        -->
        
        <!-- Delete any old/wrong properties to avoid duplicates -->
        <delete tableName="global_property">
            <where>property IN ('serialization.xstream.allowedClasses', 'ehospitalreports.serializer.whitelist.types')</where>
        </delete>
        
        <insert tableName="global_property">
            <column name="property" value="ehospitalreports.serializer.whitelist.types"/>
            <column name="property_value" value="org.openmrs.module.ehospitalreports.**"/>
            <column name="description" value="Allowed classes for ehospitalreports XStream deserialization"/>
            <column name="uuid" valueComputed="UUID()"/>
        </insert>
    </changeSet>

</databaseChangeLog>
